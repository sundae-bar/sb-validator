# ============================================================================
# Sundae Bar Validator Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# cp env.example .env

# ============================================================================
# Required Configuration
# ============================================================================

# Required: One of the following three key options must be set.

# Option 1: 12-word BIP39 mnemonic (most common)
VALIDATOR_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Option 2: Path to a Bittensor hotkey JSON file (inside the container).
# Mount your wallet directory via docker-compose volumes, then set:
# HOTKEY_PATH=/home/validator/.bittensor/wallets/<wallet_name>/hotkeys/<hotkey_name>

# Option 3: Raw private key / hex seed
# PRIVATE_KEY=0x...

# Required: Coordinator API URL
# Can be base URL (e.g., http://localhost:3002) or full path (e.g., http://localhost:3002/api/v2/validators)
API_URL=https://api.sundaebar.ai/api/v2/validators

# Required: Letta server URL
# For local server: http://localhost:8283 or http://host.docker.internal:8283 (Docker)
# For remote server: https://your-letta-server.com
LETTA_BASE_URL=http://localhost:8283

# ============================================================================
# Optional: Validator Settings
# ============================================================================

# Optional: Validator display name
DISPLAY_NAME=My Validator

# Optional: Poll interval in seconds (default: 5)
POLL_INTERVAL=5

# Optional: Heartbeat interval in seconds (default: 30)
HEARTBEAT_INTERVAL=30

# Optional: Max retries for failed requests (default: 3)
MAX_RETRIES=3

# Optional: Retry delay in milliseconds (default: 1000)
RETRY_DELAY=1000

# Optional: Log level (default: info)
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Optional: Working directory for task files (default: /tmp/validator-work)
WORK_DIR=/tmp/validator-work

# Optional: Maximum number of tasks to process concurrently (default: 1)
MAX_CONCURRENT_TASKS=1

# Optional: HTTP server port for health checks (default: 8080)
SERVER_PORT=8080

# Optional: Set to 1 to keep task files after processing (for debugging)
# KEEP_TASK_FILES=1

# ============================================================================
# Optional: sb-evals Skill Evaluation Service
# ============================================================================

# Shared secret between the validator and the sbevals sidecar container.
# docker-compose passes the same value to the sidecar as EVAL_SERVICE_API_KEY,
# so set it once here.
# SBEVALS_API_KEY=your-sbevals-api-key-here

# Optional: URL of the sb-evals service (default: http://localhost:8090).
# When running via docker-compose this is set to http://sbevals:8090 for you.
# SBEVALS_URL=http://sbevals:8090

# ============================================================================
# Optional: Evaluation Settings
# ============================================================================

# Optional: Maximum number of agent steps/tool calls per evaluation sample (default: 10)
MAX_STEPS=10

# Optional: Maximum time to wait for file embeddings to complete in minutes (default: 30)
LETTA_EMBEDDING_WAIT_MINUTES=30

# Optional: Python command to use for running letta-evals (default: python3)
LETTA_EVALS_PYTHON=python3

# Optional: Python module to use for letta-evals CLI (default: letta_evals.cli)
LETTA_EVALS_MODULE=letta_evals.cli

# Optional: GitHub personal access token for authenticated API requests (increases rate limits)
# Get from: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here

# ============================================================================
# Optional: Bittensor Weights Configuration
# ============================================================================

# Optional: Interval for fetching and submitting Bittensor weights in minutes (default: 30)
BITTENSOR_WEIGHTS_INTERVAL_MINUTES=30

# Optional: Set to true to disable on-chain weight submission (still fetches and logs) (default: false)
BITTENSOR_WEIGHTS_DISABLED=false

# ============================================================================
# Model Provider API Keys
# ============================================================================
# Skill evaluation calls these for the skill harness and the LLM-as-judge
# graders. Each challenge's suite.yaml picks the provider, and it can differ
# from one challenge to the next — so hold keys for every provider you might
# see. Most skill challenges use Chutes or OpenRouter, so set those first.
# (For agent challenges the agent's own model runs on the Letta server, not
# here; OpenAI is also used there for Letta embeddings.)

# Chutes API Key (OpenAI-compatible) — primary for most skill challenges
# CHUTES_API_KEY=your-chutes-api-key-here

# OpenRouter API Key (multi-provider) — primary for most skill challenges
# Get from: https://openrouter.ai/keys  (format: sk-or-...)
# OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# OpenAI API Key (also used by the legacy agent track for Letta embeddings)
# Get from: https://platform.openai.com/api-keys  (format: sk-...)
# OPENAI_API_KEY=sk-your-api-key-here

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys  (format: sk-ant-...)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google API Key
# Get from: https://aistudio.google.com/app/apikey  (format: AIza...)
# GOOGLE_API_KEY=AIza-your-google-api-key-here

# Together AI API Key (use either TOGETHER_API_KEY or TOGETHERAI_API_KEY)
# Get from: https://together.ai/
# TOGETHER_API_KEY=your-together-api-key-here
# TOGETHERAI_API_KEY=your-together-api-key-here

# ============================================================================
# Deprecated/Alternative Variables
# ============================================================================

# Deprecated: Use LETTA_BASE_URL instead
# LETTA_URL=http://localhost:8283
